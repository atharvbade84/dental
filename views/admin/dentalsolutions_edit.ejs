<%- include('header.ejs')%>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Dentalsolutions Update</h1>
                
              </div>
            </div>  
          </div>
          <section class="panel"> 
            <form action="/admin/dentalsolutions_edit/<%=data.ds_id %>" method="post">
                <label>Title</label>
                <input type="text" class="form-control mb-4" name="title"  value="<%=data.title %>" />
                <label>description</label>
                <textarea class="form-control mb-4" name="descriptions" ><%=data.descriptions %></textarea>
                <button class="btn btn-primary">update</button>
            </form>
        
          </section>
        </div>
      </main>

      <%- include('footer.ejs')%>