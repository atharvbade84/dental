<%- include('header.ejs')%>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Pricing</h1>
                
              </div>
            </div>  
          </div>
          <section class="panel"> 
            <form action="/admin/pricing_save" method="post" enctype="multipart/form-data">
                <label>Title</label>
                <input type="text" class="form-control mb-4" name="title" />
                <label>Description</label>
                <textarea class="form-control mb-4" name="description"></textarea>
                <label>Price</label>
                <input type="text" class="form-control mb-4" name="price" />
                <label>Procedure</label>
                <input type="text" class="form-control mb-4" name="rocedure" />
                <button class="btn btn-primary">Save</button>
            </form>
            <table class="table table-border mt-5">
                <tr>
                    <th>Sr.no</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Price</th>
                    <th>Procedure</th>
                    <th>Status</th>
                </tr>
                <% for(var i=0;i<data.length;i++){ %>
                    <tr>
                    <th><%= i+1; %></th>
                    <th><%=data[i].title; %></th>
                    <th><%=data[i].description; %></th>
                    <th><%=data[i].price; %></th>
                    <th><%=data[i].rocedure; %></th>
                    <th>
                        <a href="/admin/pricing_edit/<%=data[i].pid;%>"><button class="btn ">Edit</button></a>
                        <a href="/admin/pricing_delete/<%=data[i].pid;%>"><button class="btn ">Delete</button></a>
                    </th>
                </tr>

                <% } %>
            </table>
           
          </section>
        </div>
      </main>

      <%- include('footer.ejs')%>