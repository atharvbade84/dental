<%- include('header.ejs')%>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Appointment Confirm</h1>
                
              </div>
            </div>  
          </div>
        
            <table class="table table-border mt-5">
                <tr>
                    <th>Sr.no</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Service_id</th>
                    <th>Appointment_Date</th>
                    <th>Status</th>
                </tr>
                <% for(var i=0;i<data.length;i++){ %>
                    <tr>
                    <th><%= i+1; %></th>
                    <th><%=data[i].name; %></th>
                    <th><%=data[i].email; %></th>
                    <th><%=data[i].service_id; %></th>
                    <th><%=data[i].appointment_date%></th>
                    <th><%=data[i].status; %></th>
                  
                </tr>

                <% } %>
            </table>
          </section>
        </div>
      </main>

      <%- include('footer.ejs')%>