<%- include('header.ejs')%>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Blog update</h1>
                
              </div>
            </div>  
          </div>
          <section class="panel"> 
            <form action="/admin/blog_edit_save/<%=data[i].bid;%>/<%=data[i].bphoto;%>" method="post" enctype="multipart/form-data">
                <label>Photo</label>
                <input type="file" class="form-control mb-4" name="bphoto" />
                <img src="/images/<%=data.bphoto %>" height="50px"><br>
                <label>Date</label>
                <input type="text" class="form-control mb-4" name="bdate" value="<%=data.bdate %>" />
                <label>Title</label>
                <input type="text" class="form-control mb-4" name="btitle" value="<%=data.btitle %>" />
                <label>Description</label>
                <textarea class="form-control mb-4" name="bdescriptions"><%=data.bdescriptions %></textarea>
                <button class="btn btn-primary">Save</button>
            </form>
          </section>
        </div>
      </main>
<%- include('footer.ejs')%>